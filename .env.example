# Vimeo API credentials
# Get these from https://developer.vimeo.com/apps
VIMEO_ACCESS_TOKEN=your_vimeo_access_token

# Optional: Rate limiting settings
RATE_LIMIT_MS=1000

# Workbook path (optional, defaults to ./workbook/Agent-Workbook.md)
WORKBOOK_PATH=./workbook/Agent-Workbook.md

# RAG System - OpenRouter API
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# RAG System - Supabase
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# RAG System - Models (via OpenRouter)
EMBEDDING_MODEL=openai/text-embedding-3-small
SUMMARIZATION_MODEL=openai/gpt-4o-mini
