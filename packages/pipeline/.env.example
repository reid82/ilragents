# Vimeo API credentials
# Get these from https://developer.vimeo.com/apps
VIMEO_ACCESS_TOKEN=your_vimeo_access_token

# Optional: Rate limiting settings
RATE_LIMIT_MS=1000

# Workbook path (optional, defaults to ./workbook/Agent-Workbook.md)
WORKBOOK_PATH=./workbook/Agent-Workbook.md

# RAG System - OpenRouter API
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# RAG System - Supabase
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# RAG System - Models (via OpenRouter)
EMBEDDING_MODEL=openai/text-embedding-3-small
SUMMARIZATION_MODEL=openai/gpt-4o-mini

# Domain.com.au API (free tier - 500 calls/day)
# Register at https://developer.domain.com.au
DOMAIN_API_CLIENT_ID=your_domain_client_id
DOMAIN_API_CLIENT_SECRET=your_domain_client_secret

# Serper.dev (Google Search API for address-to-listing URL resolution)
# Get your API key from https://serper.dev/ (2,500 free queries)
SERPER_API_KEY=your_serper_api_key

# Apify (property intelligence scraping)
# Get your API token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token

# Optional: override default Apify actor IDs
# APIFY_SUBURB_ACTOR=fatihtahta/domain-com-au-scraper
# APIFY_VACANCY_ACTOR=custom/sqm-vacancy-scraper
# APIFY_SENTIMENT_ACTOR=custom/homely-suburb-scraper
# APIFY_DOMAIN_SEARCH_ACTOR=fatihtahta/domain-com-au-scraper
# APIFY_REA_SEARCH_ACTOR=azzouzana/realestate-com-au-search-pages-scraper
# APIFY_DOMAIN_DETAIL_ACTOR=stealth_mode/domain-property-details-scraper
# APIFY_REA_DETAIL_ACTOR=azzouzana/realestate-com-au-properties-pages-scraper
